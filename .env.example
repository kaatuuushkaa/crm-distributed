# App
APP_ENV=development                    # development | production
JWT_SECRET=change-me-in-production     # минимум 32 символа

# Task service
TASK_SERVICE_PORT=8080
TASK_SERVICE_GRACEFUL_TIMEOUT=30s

# Notification Service
HTTP_PORT=8081
GRPC_PORT=50051

# Document Service
# HTTP_PORT=8082         # переопределить для document-service
# GRPC_PORT=50052        # переопределить для document-service

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_secret           # сменить в production
POSTGRES_DB=crm
POSTGRES_SSLMODE=disable               # disable | require | verify-full

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                        # оставить пустым для dev
REDIS_DB=0

# Apache Kafka
KAFKA_BROKERS=localhost:9092           # через запятую для кластера
KAFKA_GROUP_ID=notification-service    # уникален на каждый consumer
KAFKA_TOPICS=task.created,task.updated,task.deleted

# MinIO (S3-совместимое хранилище)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin            # сменить в production
MINIO_SECRET_KEY=minioadmin            # сменить в production
MINIO_BUCKET=crm-documents
MINIO_USE_SSL=false                    # true в production
MINIO_REGION=us-east-1

# Логирование
LOG_LEVEL=info                         # debug | info | warn | error